---
import '../main.css';
interface Props {
  readonly frontmatter: {
    readonly title: string;
  };
}
const { frontmatter } = Astro.props;
---

<!doctype html>
<html lang='ja'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width,initial-scale=1' />
    <meta name='color-scheme' content='light dark' />
    <link type='icon' href='/favicon.ico' />
    <meta name='generator' content={Astro.generator} />

    <!-- fonts -->
    <link
      rel='preload'
      as='font'
      href='https://api.tktb-tess.dev/fonts/Inter/InterVariable.woff2'
      crossorigin='anonymous'
    />
    <link
      rel='preload'
      as='font'
      href='https://api.tktb-tess.dev/fonts/Inter/InterVariable-Italic.woff2'
      crossorigin='anonymous'
    />
    <!-- font-face -->
    <link
      rel='stylesheet'
      href='https://api.tktb-tess.dev/fonts/Inter/font-face.css'
      crossorigin='anonymous'
    />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <header>
      <h1 id='title'>
        {frontmatter.title}
      </h1>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
